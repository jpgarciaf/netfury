# =============================================================================
# NetFury - Benchmark 360 Configuration
# =============================================================================
# Copy this file to .env and fill in your API keys.

# --- LLM Provider Selection ---
# Options: anthropic | openai | google | local
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-20250514

# --- API Keys ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...

# --- Local Model (Ollama) ---
OLLAMA_BASE_URL=http://localhost:11434

# --- Multi-model Evaluation ---
# Comma-separated list of models to compare in evaluator
EVAL_MODELS=claude-sonnet-4-20250514,gpt-4o,gpt-4o-mini,gemini-2.0-flash
EVAL_ISP=xtrim

# --- Scraping ---
SCRAPE_DELAY_MIN=2.0
SCRAPE_DELAY_MAX=5.0
SCREENSHOT_WIDTH=1440
SCREENSHOT_HEIGHT=900
